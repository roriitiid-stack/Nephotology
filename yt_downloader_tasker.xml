<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════════╗
║         YouTube Audio Downloader — Tasker + Termux           ║
╚══════════════════════════════════════════════════════════════╝

REQUIREMENTS (one-time setup):
───────────────────────────────
1. Install Termux        → F-Droid (NOT Play Store — that build is outdated)
2. Install Termux:Tasker → F-Droid
3. Open Termux and run:
       pkg update && pkg install python ffmpeg
       pip install yt-dlp
       termux-setup-storage        ← grants /sdcard access
4. Open the Termux:Tasker app and enable "Allow External Apps"

HOW TO USE:
───────────────────────────────
Option A — Share sheet (recommended):
  YouTube → Share → scroll to "Tasker" → tap "YT Audio Download"

Option B — Clipboard auto-detect:
  Copy any YouTube URL (long-press address bar in browser, or
  YouTube → Share → Copy link). The profile fires automatically.

Downloads land in: /sdcard/Music/
-->

<TaskerData sr="" dvi="1" tv="6.3.0">

    <!-- ════════════════════════════════════════════════════════
         PROFILE: fires when a YouTube URL lands on the clipboard
         ════════════════════════════════════════════════════════ -->
    <Profile sr="prof1" ve="2">
        <cdate>1716000000000</cdate>
        <edate>1716000000000</edate>
        <id>1</id>
        <mid0>1</mid0>
        <nme>YT Clipboard Monitor</nme>
        <!-- Event › Variable › Variable Set -->
        <Event sr="con0" ve="2">
            <code>9</code>
            <pri>0</pri>
            <!-- Watch the %CLIP variable for any YouTube URL -->
            <Str sr="arg0" ve="3">CLIP</Str>
            <Str sr="arg1" ve="3">*youtube.com*</Str>
            <Int sr="arg2" ve="2">
                <var>0</var>
            </Int>
        </Event>
    </Profile>

    <!-- ════════════════════════════════════════════════════════
         TASK: YT Audio Download
         Triggered by:  (a) clipboard profile above, or
                        (b) sharing from YouTube → Tasker
         ════════════════════════════════════════════════════════ -->
    <Task sr="task1" ve="2">
        <cdate>1716000000000</cdate>
        <edate>1716000000000</edate>
        <id>1</id>
        <nme>YT Audio Download</nme>
        <priority>5</priority>

        <!-- ── Step 1: grab URL from share intent (%SHARE_TEXT) ── -->
        <Action sr="act0" ve="7">
            <code>37</code><!-- Variable Set -->
            <Str sr="arg0" ve="3">YT_URL</Str>
            <Str sr="arg1" ve="3">%SHARE_TEXT</Str>
            <Int sr="arg2" ve="2"><var>0</var></Int>
            <Int sr="arg3" ve="2"><var>0</var></Int>
            <Int sr="arg4" ve="2"><var>0</var></Int>
            <Int sr="arg5" ve="2"><var>0</var></Int>
            <Str sr="arg6" ve="3"/>
        </Action>

        <!-- ── Step 2: if share intent was empty, fall back to clipboard ── -->
        <Action sr="act1" ve="7">
            <code>536</code><!-- If -->
            <Str sr="arg0" ve="3">%YT_URL</Str>
            <Int sr="arg1" ve="2"><var>0</var></Int><!-- eq -->
            <Str sr="arg2" ve="3"></Str>
            <Int sr="arg3" ve="2"><var>0</var></Int>
        </Action>
        <Action sr="act2" ve="7">
            <code>37</code><!-- Variable Set YT_URL = %CLIP -->
            <Str sr="arg0" ve="3">YT_URL</Str>
            <Str sr="arg1" ve="3">%CLIP</Str>
            <Int sr="arg2" ve="2"><var>0</var></Int>
            <Int sr="arg3" ve="2"><var>0</var></Int>
            <Int sr="arg4" ve="2"><var>0</var></Int>
            <Int sr="arg5" ve="2"><var>0</var></Int>
            <Str sr="arg6" ve="3"/>
        </Action>
        <Action sr="act3" ve="7">
            <code>537</code><!-- End If -->
        </Action>

        <!-- ── Step 3: confirm dialog ── -->
        <Action sr="act4" ve="7">
            <code>135</code><!-- Alert › Show Dialog -->
            <Str sr="arg0" ve="3">Download Audio?</Str>
            <Str sr="arg1" ve="3">Save MP3 from:

%YT_URL</Str>
            <Str sr="arg2" ve="3">Download,Cancel</Str>
            <Str sr="arg3" ve="3"/>
            <Int sr="arg4" ve="2"><var>0</var></Int>
            <Str sr="arg5" ve="3">DL_CHOICE</Str>
        </Action>

        <!-- ── Step 4: only proceed if user tapped Download ── -->
        <Action sr="act5" ve="7">
            <code>536</code><!-- If %DL_CHOICE eq Download -->
            <Str sr="arg0" ve="3">%DL_CHOICE</Str>
            <Int sr="arg1" ve="2"><var>0</var></Int>
            <Str sr="arg2" ve="3">Download</Str>
            <Int sr="arg3" ve="2"><var>0</var></Int>
        </Action>

        <!-- ── Step 5: fire yt-dlp inside Termux (background, no popup) ── -->
        <!--
             Requires Termux:Tasker plugin with "Allow External Apps" enabled.
             Saves to /sdcard/Music/ as MP3 with embedded thumbnail + tags.
        -->
        <Action sr="act6" ve="7">
            <code>100</code><!-- Run Shell -->
            <Str sr="arg0" ve="3">am broadcast --user 0 \
  -a com.termux.RUN_COMMAND \
  --es com.termux.RUN_COMMAND_PATH '/data/data/com.termux/files/usr/bin/bash' \
  --esa com.termux.RUN_COMMAND_ARGUMENTS '-c,yt-dlp -x --audio-format mp3 --embed-thumbnail --add-metadata --no-playlist -o /sdcard/Music/%%(title)s.%%(ext)s "'"'"'%YT_URL'"'"'"' \
  --ez com.termux.RUN_COMMAND_BACKGROUND true \
  com.termux</Str>
            <Int sr="arg1" ve="2"><var>0</var></Int><!-- Use Root: No -->
            <Str sr="arg2" ve="3">SHELL_OUT</Str>
            <Int sr="arg3" ve="2"><var>0</var></Int>
            <Int sr="arg4" ve="2"><var>60</var></Int><!-- timeout 60s -->
        </Action>

        <!-- ── Step 6: toast so you know it's running ── -->
        <Action sr="act7" ve="7">
            <code>30</code><!-- Flash (toast) -->
            <Str sr="arg0" ve="3">Downloading to Music folder...</Str>
            <Int sr="arg1" ve="2"><var>1</var></Int><!-- Long toast -->
        </Action>

        <Action sr="act8" ve="7">
            <code>537</code><!-- End If -->
        </Action>

    </Task>

</TaskerData>
